AUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=replace-with-google-oauth-client-id
AUTH_GOOGLE_SECRET=replace-with-google-oauth-client-secret
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.4-nano

# Production / deploy target: Supabase Postgres
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SECRET_KEY=replace-with-supabase-secret-key
SUPABASE_STORAGE_BUCKET=exam-source-images
ADMIN_EMAILS=admin1@example.com,admin2@example.com
EXAM_SET_GENERATE_LIMIT=5
CRON_SECRET=replace-with-cron-secret

# Local development fallback
LOCAL_DB_PATH=data/app.db
